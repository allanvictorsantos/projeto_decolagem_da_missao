# Sistema de verificação de pré-decolagem

# Telemetria simulada
temperatura_interna = 22
temperatura_externa = 30
integridade_estrutural = 1
energia = 85
pressao_tanques = 60
modulos_criticos = "ONLINE"

print("=== SISTEMA DE VERIFICAÇÃO DE PRÉ-DECOLAGEM ===")

# Verificações

if integridade_estrutural == 0:
    resultado = "DECOLAGEM ABORTADA - FALHA ESTRUTURAL"

elif energia < 70:
    resultado = "DECOLAGEM ABORTADA - ENERGIA INSUFICIENTE"

elif temperatura_interna < 18 or temperatura_interna > 27:
    resultado = "DECOLAGEM ABORTADA - TEMPERATURA INTERNA FORA DO LIMITE"

elif pressao_tanques < 30 or pressao_tanques > 80:
    resultado = "DECOLAGEM ABORTADA - PRESSÃO DOS TANQUES IRREGULAR"

elif modulos_criticos != "ONLINE":
    resultado = "DECOLAGEM ABORTADA - MÓDULOS CRÍTICOS OFFLINE"

else:
    resultado = "PRONTO PARA DECOLAR"

print("Resultado:", resultado)